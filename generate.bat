@echo off
git submodule update --init --recursive
if exist build rmdir /s /q build
powershell -NoProfile -ExecutionPolicy Bypass -Command "$p='data/launcher/main.html'; $c=Get-Content $p -Raw; $c=$c.Replace('<title>BOIII</title>','<title>Swifly BOIII</title>'); $c=$c.Replace('<span class=\"title-white title-big\">E</span><span class=\"title-white\">ZZ</span>','<span class=\"title-white title-big\">S</span><span class=\"title-white\">wifly</span>'); $c=$c.Replace('Call of Duty: Black Ops 3 enhanced with our modifications.','Call of Duty: Black Ops 3 enhanced by Swifly BOIII.'); $c=$c.Replace('Latest (Auto-update)','Latest'); if ($c -notmatch 'data-option=\"vanilla\"') { $marker='              <div class=\"launch-option-card\" data-option=\"console\"'; $insert='              <div class=\"launch-option-card\" data-option=\"vanilla\" title=\"Enable BOIII Vanilla campaign/speedrun-friendly behavior\"><span class=\"launch-option-dot\"></span><span class=\"launch-option-name\">Vanilla Mode</span></div>' + [Environment]::NewLine; $c=$c.Replace($marker, $insert + $marker); }; Set-Content -Path $p -Value $c -NoNewline"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$p='src/client/launcher/launcher.cpp'; $c=Get-Content $p -Raw; $c=$c.Replace('html_window window(\"EZZ BOIII\", 1260, 680);','html_window window(\"Swifly BOIII\", 1260, 680);'); Set-Content -Path $p -Value $c -NoNewline"
tools\premake5 %* vs2022
